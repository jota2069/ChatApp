<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClientApp.MainWindow"
        Title="Чатик"
        Width="800" Height="550"
        MinWidth="600" MinHeight="400"
        Background="#18181B"
        Foreground="#F4F4F5">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Шапка подключения -->
        <Border Grid.Row="0" Background="#27272A" Padding="15" 
                BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*, Auto">
                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="IP:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#A1A1AA"/>
                    <TextBox x:Name="HostTextBox" Text="127.0.0.1" Width="110" VerticalAlignment="Center" 
                             Margin="0,0,12,0" CornerRadius="6" Background="#18181B" BorderThickness="0"/>

                    <TextBlock Text="Порт:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#A1A1AA"/>
                    <TextBox x:Name="PortTextBox" Text="5000" Width="60" VerticalAlignment="Center" 
                             Margin="0,0,12,0" CornerRadius="6" Background="#18181B" BorderThickness="0"/>

                    <TextBlock Text="Ник:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#A1A1AA"/>
                    <TextBox x:Name="NickTextBox" Watermark="Введите ник" Width="120" VerticalAlignment="Center" 
                             Margin="0,0,16,0" CornerRadius="6" Background="#18181B" BorderThickness="0"/>

                    <Button x:Name="ConnectButton" Content="Подключиться" Width="120" 
                            Click="ConnectButton_OnClick" Margin="0,0,8,0" 
                            Background="#10B981" Foreground="White" CornerRadius="6" FontWeight="SemiBold"/>
                    
                    <Button x:Name="DisconnectButton" Content="Отключиться" Width="110" 
                            IsEnabled="False" Click="DisconnectButton_OnClick" 
                            Background="#EF4444" Foreground="White" CornerRadius="6" FontWeight="SemiBold"/>
                </WrapPanel>

                <!-- Статус -->
                <Border Grid.Column="1" Background="#18181B" CornerRadius="6" Padding="12,6">
                    <TextBlock x:Name="StatusText" Text="Не подключён" VerticalAlignment="Center" 
                               FontWeight="Medium" Foreground="#A1A1AA"/>
                </Border>
            </Grid>
        </Border>

        <!-- Центральная область: Чат и Пользователи -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 220" Margin="15">
            
            <!-- Лента сообщений -->
            <Border Grid.Column="0" Background="#27272A" CornerRadius="8" Margin="0,0,15,0" 
                    BorderBrush="#3F3F46" BorderThickness="1">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="15,10" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                        <TextBlock Text="Чат комнаты" FontWeight="SemiBold" Foreground="#E4E4E7"/>
                    </Border>
                    <ScrollViewer x:Name="MessagesScrollViewer" VerticalScrollBarVisibility="Auto" Margin="10">
                        <ListBox x:Name="MessagesListBox" Background="Transparent" BorderThickness="0" 
                                 SelectionMode="Single" Foreground="#D4D4D8">
                            <ListBox.Styles>
                                <!-- Делаем элементы списка более просторными -->
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </ListBox.Styles>
                        </ListBox>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Список онлайн -->
            <Border Grid.Column="1" Background="#27272A" CornerRadius="8" 
                    BorderBrush="#3F3F46" BorderThickness="1">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="15,10" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                        <TextBlock Text="В сети" FontWeight="SemiBold" Foreground="#E4E4E7"/>
                    </Border>
                    <ListBox x:Name="UsersListBox" Background="Transparent" BorderThickness="0" 
                             SelectionMode="Single" Margin="8" Foreground="#A1A1AA">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </ListBox.Styles>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Нижняя панель ввода (Подвал) -->
        <Border Grid.Row="2" Background="#27272A" Padding="15" 
                BorderBrush="#3F3F46" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*, Auto">
                <TextBox x:Name="MessageInputBox" Grid.Column="0" Margin="0,0,12,0" 
                         Watermark="Написать сообщение..." 
                         CornerRadius="6" Background="#18181B" BorderThickness="1" BorderBrush="#3F3F46"
                         Padding="12,10" FontSize="14"
                         KeyDown="MessageInputBox_OnKeyDown"/>
                         
                <Button x:Name="SendButton" Grid.Column="1" Content="➤ Отправить" Width="130" 
                        IsEnabled="False" Click="SendButton_OnClick" 
                        Background="#3B82F6" Foreground="White" CornerRadius="6" 
                        FontWeight="Bold" Padding="0,10" HorizontalContentAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>