<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ServerApp.MainWindow"
        Title="Чатик Сервер"
        Width="650" Height="450"
        MinWidth="500" MinHeight="350"
        Background="#18181B"
        Foreground="#F4F4F5">

    <Grid RowDefinitions="Auto, *">
        
        <!-- Верхняя панель управления (Шапка) -->
        <Border Grid.Row="0" Background="#27272A" Padding="15" 
                BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*, Auto">
                
                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Порт:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#A1A1AA"/>
                    <TextBox x:Name="PortTextBox" Text="5000" Width="80" VerticalAlignment="Center" 
                             Margin="0,0,12,0" CornerRadius="6" Background="#18181B" BorderThickness="0"/>
                    
                    <Button x:Name="StartButton" Content="Запустить" Width="110" 
                            Click="StartButton_OnClick" Margin="0,0,8,0" 
                            Background="#3B82F6" Foreground="White" CornerRadius="6" FontWeight="SemiBold"/>
                    
                    <Button x:Name="StopButton" Content="Остановить" Width="110" 
                            IsEnabled="False" Click="StopButton_OnClick" Margin="0,0,16,0" 
                            Background="#EF4444" Foreground="White" CornerRadius="6" FontWeight="SemiBold"/>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Статус:" Foreground="#A1A1AA" Margin="0,0,6,0"/>
                        <TextBlock x:Name="StatusText" Text="Остановлен" Foreground="#FCA5A5" FontWeight="Medium"/>
                    </StackPanel>
                </WrapPanel>

                <!-- Плашка со счетчиком -->
                <Border Grid.Column="1" Background="#3F3F46" CornerRadius="6" Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Клиентов онлайн:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#D4D4D8"/>
                        <TextBlock x:Name="ClientCountText" Text="0" VerticalAlignment="Center" 
                                   FontWeight="Bold" Foreground="#10B981" FontSize="16"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Основная область с логами -->
        <Border Grid.Row="1" Margin="15" Background="#09090B" 
                CornerRadius="8" BorderBrush="#27272A" BorderThickness="1">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#27272A" Padding="10,6" CornerRadius="7,7,0,0">
                    <TextBlock Text="Terminal Log" Foreground="#A1A1AA" FontSize="12" FontWeight="SemiBold"/>
                </Border>
                
                <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" Margin="10">
                    <ListBox x:Name="LogListBox" Background="Transparent" BorderThickness="0" 
                             SelectionMode="Single" Foreground="#10B981" FontFamily="Consolas, Monospace"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

    </Grid>
</Window>